{
  "name": "minutodash",
  "version": "1.0.0",
  "description": "Dashboard de cibersegurança em tempo real - automação de 9 APIs",
  "main": "server-apis-complete.js",
  "scripts": {
    "start": "node server-apis-complete.js",
    "dev": "nodemon server-apis-complete.js",
    "lint": "eslint . --ext .js",
